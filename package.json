{
  "name": "@dendavidov/eslint-config-react",
  "version": "2.2.2",
  "description": "Shareable ESLint config for React + TypeScript (ESLint 9+ flat config), supporting Node.js 24.x.",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "license": "MIT",
  "author": "Denis Davydov <mail@dendavidov.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:dendavidov/eslint-config-react.git"
  },
  "bugs": {
    "url": "https://github.com/dendavidov/eslint-config-react/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "LICENSE",
    "README.md",
    "src/index.js",
    "src/index.d.ts"
  ],
  "scripts": {
    "test": "node scripts/verify-node-pins.cjs && NODE_OPTIONS=--experimental-vm-modules jest --watchAll=false",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@eslint/js": "^9.39.0",
    "eslint": "^9.39.0"
  },
  "peerDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-testing-library": "^7.15.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-testing-library": "^7.15.4",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2"
  }
}
